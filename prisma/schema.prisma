// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TEACHER
  STUDENT
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id                      Int                      @id @default(autoincrement())
  email                   String                   @unique
  password                String
  role                    Role                     @default(TEACHER)
  name                    String
  
  // A Teacher owns Classrooms
  classrooms              Classroom[]              
  
  // A Student provides Feedback
  feedbacks               Feedback[]               
  
  // Existing relations
  disasterSurveys         DisasterSurvey[]
  disasterSurveyResponses DisasterSurveyResponse[]
}

model Classroom {
  id        Int      @id @default(autoincrement())
  name      String
  teacherId Int
  teacher   User     @relation(fields: [teacherId], references: [id])
  surveys   Survey[]
}

model Survey {
  id        Int        @id @default(autoincrement())
  title     String
  createdAt DateTime   @default(now())
  classId   Int
  classroom Classroom  @relation(fields: [classId], references: [id])
  responses Feedback[]
}

model Feedback {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  
  // Fields from classroom.ejs
  grade           String   // Maps to <select name="grade">
  subject         String   // Maps to <select name="subject">
  rating          Int      // Maps to <input name="rating"> (1-5)
  favoriteLesson  String   // Maps to <input name="favoriteLesson">
  suggestions     String?  // Maps to <textarea name="suggestions">
  anonymous       Boolean  @default(false) // Maps to <input name="anonymous">

  // Relations
  survey          Survey   @relation(fields: [surveyId], references: [id])
  surveyId        Int
  
  // Link to the User (Student) who submitted
  student         User?    @relation(fields: [studentId], references: [id])
  studentId       Int?
}


// ──────────────────────────────────────────────
//  Disaster Preparedness Survey
// ──────────────────────────────────────────────

model DisasterSurvey {
  id        Int                      @id @default(autoincrement())
  title     String
  category  DisasterSurveyCategory
  createdAt DateTime                 @default(now())
  adminId   Int
  admin     User                     @relation(fields: [adminId], references: [id])
  responses DisasterSurveyResponse[]
}

model DisasterSurveyResponse {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())

  // Household Readiness
  householdSize        Int?
  hasEmergencyPlan     Boolean?
  planPracticeFreq     String?   // "never" | "rarely" | "sometimes" | "regularly"
  awareCommunityAlerts Boolean?

  // Emergency Supplies
  hasGoBag        Boolean?
  waterSupplyDays Int?
  hasFirstAidKit  Boolean?
  hasFlashlight   Boolean?
  hasBatteryRadio Boolean?
  foodSupplyDays  Int?

  // Evacuation Planning
  knowsEvacuationRoute      Boolean?
  hasDesignatedMeetingPoint Boolean?
  practisedEvacuation       Boolean?
  evacPracticeFreq          String?  // "never" | "once" | "annually" | "biannually"
  knowsLocalShelter         Boolean?

  // General / open-ended
  biggestConcern     String?
  additionalComments String?

  survey       DisasterSurvey @relation(fields: [surveyId], references: [id])
  surveyId     Int
  respondent   User?          @relation(fields: [respondentId], references: [id])
  respondentId Int?
}


enum DisasterSurveyCategory {
  HOUSEHOLD_READINESS
  EMERGENCY_SUPPLIES
  EVACUATION_PLANNING
}