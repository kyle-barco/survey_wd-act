<%- include('../partials/header') %>

<style>
  :root { --echo-green:#2d7a3a; --echo-light:#eaf3de; }
  .list-wrap { max-width:800px; margin:2rem auto; padding:0 1rem 3rem; }
  .list-top  { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:10px; }
  .list-title { font-size:1.5rem; font-weight:700; color:var(--echo-green); }
  .btn-green { padding:9px 20px; background:var(--echo-green); color:#fff; border:none; border-radius:8px; font-size:14px; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:6px; font-weight:600; }
  .btn-green:hover { background:#245f2d; }
  .survey-card { background:#fff; border:1px solid #e0e0e0; border-radius:12px; padding:1.25rem 1.5rem; margin-bottom:12px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; transition:border-color .2s; }
  .survey-card:hover { border-color:var(--echo-green); }
  .sc-info {}
  .sc-title { font-size:15px; font-weight:700; color:#222; margin-bottom:4px; }
  .sc-meta  { font-size:13px; color:#888; display:flex; gap:14px; flex-wrap:wrap; }
  .sc-meta span { display:flex; align-items:center; gap:4px; }
  .sc-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .btn-sm { padding:6px 14px; border-radius:7px; font-size:13px; cursor:pointer; border:1px solid #ddd; background:#fff; color:#333; text-decoration:none; display:inline-flex; align-items:center; gap:5px; transition:all .15s; }
  .btn-sm:hover { background:#f5f5f5; }
  .btn-sm.green { border-color:var(--echo-green); color:var(--echo-green); }
  .btn-sm.green:hover { background:var(--echo-light); }
  .btn-sm.red { border-color:#e53e3e; color:#e53e3e; }
  .btn-sm.red:hover { background:#fff5f5; }
  .active-pill { font-size:11px; padding:2px 9px; border-radius:999px; background:var(--echo-light); color:var(--echo-green); font-weight:700; }
  .empty { text-align:center; padding:3rem; color:#aaa; border:1.5px dashed #ddd; border-radius:12px; }
</style>

<div class="list-wrap">
  <div class="list-top">
    <div class="list-title">📋 My Custom Surveys</div>
    <a href="/surveys/custom/builder" class="btn-green">＋ New Survey</a>
  </div>

  <% if (!surveys || surveys.length === 0) { %>
    <div class="empty">
      <div style="font-size:2.5rem;margin-bottom:.75rem;">📝</div>
      <div style="font-size:15px;font-weight:600;margin-bottom:.5rem;">No surveys yet</div>
      <div style="margin-bottom:1.5rem;">Create your first custom survey and share it with students.</div>
      <a href="/surveys/custom/builder" class="btn-green">Create Survey</a>
    </div>
  <% } else { %>
    <% surveys.forEach(s => { %>
      <div class="survey-card">
        <div class="sc-info">
          <div class="sc-title"><%= s.title %> <span class="active-pill"><%= s.isActive ? 'Active' : 'Inactive' %></span></div>
          <div class="sc-meta">
            <span>📝 <%= s._count.questions %> question<%= s._count.questions !== 1 ? 's' : '' %></span>
            <span>👥 <%= s._count.responses %> response<%= s._count.responses !== 1 ? 's' : '' %></span>
            <span>🗓 <%= new Date(s.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></span>
          </div>
        </div>
        <div class="sc-actions">
          <a href="/surveys/custom/<%= s.id %>/results" class="btn-sm green">📊 Results</a>
          <a href="/surveys/custom/<%= s.id %>/edit"    class="btn-sm">✏️ Edit</a>
          <button class="btn-sm red" onclick="deleteSurvey(<%= s.id %>, this)">🗑 Delete</button>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<script>
  async function deleteSurvey(id, btn) {
    if (!confirm('Delete this survey and all responses? This cannot be undone.')) return;
    btn.disabled = true; btn.textContent = 'Deleting…';
    try {
      const res = await fetch(`/surveys/custom/${id}`, { method: 'DELETE' });
      const d   = await res.json();
      if (d.success) btn.closest('.survey-card').remove();
      else { alert('Failed to delete.'); btn.disabled = false; btn.textContent = '🗑 Delete'; }
    } catch { alert('Network error'); btn.disabled = false; btn.textContent = '🗑 Delete'; }
  }
</script>

<%- include('../partials/footer') %>
