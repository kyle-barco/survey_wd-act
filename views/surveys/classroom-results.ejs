<%- include('../partials/header') %>

<div class="dashboard-container">
  <div class="page-header">
    <h1>📊 Classroom Feedback Results</h1>
    <p>Filter and analyze student feedback</p>
  </div>

  <!-- Filter Bar -->
  <div class="section-card filter-bar">
    <form method="GET" action="/surveys/classroom-feedback/results" class="filter-form">
      <div class="form-group">
        <label>Filter by Subject</label>
        <select name="subject">
          <option value="">All Subjects</option>
          <option value="Math" <%= subject === 'Math' ? 'selected' : '' %>>Math</option>
          <option value="Science" <%= subject === 'Science' ? 'selected' : '' %>>Science</option>
          <option value="English" <%= subject === 'English' ? 'selected' : '' %>>English</option>
          <option value="Filipino" <%= subject === 'Filipino' ? 'selected' : '' %>>Filipino</option>
          <option value="Araling Panlipunan" <%= subject === 'Araling Panlipunan' ? 'selected' : '' %>>Araling Panlipunan</option>
          <option value="MAPEH" <%= subject === 'MAPEH' ? 'selected' : '' %>>MAPEH</option>
        </select>
      </div>
      <div class="form-group">
        <label>Filter by Rating</label>
        <select name="rating">
          <option value="">All Ratings</option>
          <% for(let i = 5; i >= 1; i--) { %>
            <option value="<%= i %>" <%= rating == i ? 'selected' : '' %>><%= i %> Star<%= i > 1 ? 's' : '' %></option>
          <% } %>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit" class="btn-primary">Apply Filter</button>
        <a href="/surveys/classroom-feedback/results" class="btn-secondary">Reset</a>
      </div>
    </form>
  </div>

  <div class="section-card">
    <div class="results-meta">
      <strong><%= feedbacks.length %></strong> result<%= feedbacks.length !== 1 ? 's' : '' %> found
    </div>
    <% if (feedbacks.length === 0) { %>
      <p class="empty-state">No feedback found for the selected filters.</p>
    <% } else { %>
    <table class="data-table" id="feedbackTable">
      <thead>
        <tr>
          <th>Student</th>
          <th>Grade & Section</th>
          <th>Subject</th>
          <th>Rating</th>
          <th>Favorite Lesson</th>
          <th>Suggestions</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% feedbacks.forEach(f => { %>
        <tr>
          <td><%= f.isAnonymous ? '🕵️ Anonymous' : (f.name || f.user?.name || '—') %></td>
          <td><%= f.gradeSection %></td>
          <td><span class="subject-tag"><%= f.subject %></span></td>
          <td>
            <% for(let i = 0; i < 5; i++) { %>
              <span class="<%= i < f.teacherRating ? 'star star--filled' : 'star' %>">★</span>
            <% } %>
          </td>
          <td><%= f.favoriteLesson %></td>
          <td class="suggestion-cell"><%= f.suggestions %></td>
          <td><%= new Date(f.createdAt).toLocaleDateString('en-PH') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
