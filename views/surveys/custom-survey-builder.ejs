<%- include('../partials/header') %>

<style>
  :root { --echo-green: #2d7a3a; --echo-light: #eaf3de; }
  .sb-wrap { max-width: 780px; margin: 2rem auto; padding: 0 1rem 3rem; }
  .sb-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:10px; }
  .sb-heading { font-size:1.5rem; font-weight:600; color:var(--echo-green); display:flex; align-items:center; gap:8px; }
  .sb-actions { display:flex; gap:8px; }
  .btn { padding:8px 18px; border-radius:8px; font-size:14px; cursor:pointer; border:1px solid #ccc; background:#fff; transition:all .15s; }
  .btn:hover { background:#f5f5f5; }
  .btn-green { background:var(--echo-green); color:#fff; border-color:var(--echo-green); }
  .btn-green:hover { background:#245f2d; }
  .btn-outline { border-color:var(--echo-green); color:var(--echo-green); }
  .btn-outline:hover { background:var(--echo-light); }
  .meta-card { background:#fff; border:1px solid #e0e0e0; border-radius:12px; padding:1.25rem 1.5rem; margin-bottom:1rem; border-left:4px solid var(--echo-green); }
  .meta-card input, .meta-card textarea { width:100%; border:none; outline:none; font-family:inherit; resize:none; background:transparent; }
  .meta-card input { font-size:1.25rem; font-weight:600; color:#222; margin-bottom:6px; }
  .meta-card textarea { font-size:14px; color:#666; }
  .questions-list { display:flex; flex-direction:column; gap:10px; }
  .q-card { background:#fff; border:1px solid #e0e0e0; border-radius:12px; padding:1rem 1.25rem; position:relative; transition:border-color .2s, box-shadow .2s; }
  .q-card.dragging { opacity:.4; }
  .q-card.drag-over { border-color:var(--echo-green); box-shadow:0 0 0 2px rgba(45,122,58,.2); }
  .q-row { display:flex; align-items:flex-start; gap:10px; }
  .drag-handle { cursor:grab; color:#bbb; font-size:20px; margin-top:4px; user-select:none; }
  .drag-handle:active { cursor:grabbing; }
  .q-num { font-size:12px; font-weight:700; color:var(--echo-green); min-width:22px; margin-top:6px; }
  .q-body { flex:1; }
  .q-label-inp { width:100%; border:none; border-bottom:1.5px solid #e0e0e0; outline:none; font-size:15px; font-weight:600; padding:3px 0 7px; margin-bottom:10px; font-family:inherit; }
  .q-label-inp:focus { border-bottom-color:var(--echo-green); }
  .q-meta { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:10px; }
  .type-badge { font-size:11px; background:var(--echo-light); color:var(--echo-green); padding:3px 10px; border-radius:999px; font-weight:600; }
  .type-sel { border:1px solid #ddd; border-radius:6px; background:#fafafa; font-size:13px; padding:4px 8px; color:#333; cursor:pointer; outline:none; font-family:inherit; }
  .req-label { font-size:13px; color:#666; display:flex; align-items:center; gap:5px; cursor:pointer; }
  .req-label input { accent-color:var(--echo-green); }
  .q-ctrls { display:flex; gap:5px; margin-top:2px; }
  .icon-btn { background:none; border:none; cursor:pointer; color:#bbb; font-size:16px; padding:5px; border-radius:6px; transition:background .15s, color .15s; }
  .icon-btn:hover { background:#f5f5f5; color:#333; }
  .icon-btn.del:hover { color:#e53e3e; background:#fff5f5; }
  .choices-list { display:flex; flex-direction:column; gap:7px; }
  .choice-row { display:flex; align-items:center; gap:8px; }
  .choice-icon { color:#bbb; font-size:16px; flex-shrink:0; }
  .choice-inp { flex:1; border:none; border-bottom:1px solid #e0e0e0; outline:none; font-size:14px; padding:2px 0 5px; font-family:inherit; }
  .choice-inp:focus { border-bottom-color:var(--echo-green); }
  .add-choice { background:none; border:none; cursor:pointer; font-size:13px; color:var(--echo-green); padding:5px 0; display:flex; align-items:center; gap:5px; margin-top:5px; font-family:inherit; }
  .preview-box { border:1px solid #e0e0e0; border-radius:8px; padding:8px 12px; font-size:13px; color:#bbb; margin-top:6px; }
  .preview-box.tall { min-height:56px; }
  .rating-stars { font-size:22px; color:#e2c94b; margin-top:6px; letter-spacing:2px; }
  .scale-dots { display:flex; gap:5px; margin-top:6px; flex-wrap:wrap; }
  .scale-dot { width:30px; height:30px; border-radius:50%; border:1px solid #ddd; display:flex; align-items:center; justify-content:center; font-size:12px; color:#999; }
  .scale-dot:first-child { border-color:var(--echo-green); color:var(--echo-green); }
  .add-q-section { margin-top:1.25rem; }
  .add-q-label { font-size:12px; color:#888; text-transform:uppercase; letter-spacing:.06em; margin-bottom:8px; }
  .add-q-grid { display:flex; gap:8px; flex-wrap:wrap; }
  .add-q-btn { padding:8px 14px; border-radius:8px; border:1.5px dashed #ccc; background:#fafafa; color:#555; font-size:13px; cursor:pointer; display:flex; align-items:center; gap:6px; font-family:inherit; transition:all .15s; }
  .add-q-btn:hover { border-color:var(--echo-green); color:var(--echo-green); background:var(--echo-light); }
  .empty-state { text-align:center; padding:2.5rem; color:#999; border:1.5px dashed #ddd; border-radius:12px; }
  .save-bar { position:sticky; bottom:0; background:#fff; border-top:1px solid #e0e0e0; padding:12px 0; margin-top:1.5rem; display:flex; justify-content:flex-end; gap:10px; }
  #toast { position:fixed; top:20px; right:20px; background:#2d7a3a; color:#fff; padding:12px 20px; border-radius:8px; font-size:14px; display:none; z-index:999; box-shadow:0 4px 12px rgba(0,0,0,.15); }
</style>

<div class="sb-wrap">
  <div class="sb-top">
    <div class="sb-heading">📋 Survey Builder</div>
    <div class="sb-actions">
      <button class="btn btn-outline" onclick="openPreview()">👁 Preview</button>
      <button class="btn btn-green" onclick="saveSurvey()">
        <%= survey ? '💾 Update Survey' : '🚀 Save Survey' %>
      </button>
    </div>
  </div>

  <div class="meta-card">
    <input id="form-title" type="text" placeholder="Survey Title" value="<%= survey ? survey.title : '' %>" />
    <textarea id="form-desc" rows="2" placeholder="Description (optional)"><%= survey ? survey.description || '' : '' %></textarea>
  </div>

  <div class="questions-list" id="questions-list"></div>

  <div class="add-q-section">
    <div class="add-q-label">Add a question</div>
    <div class="add-q-grid">
      <button class="add-q-btn" onclick="addQ('short')">📝 Short text</button>
      <button class="add-q-btn" onclick="addQ('long')">📄 Long text</button>
      <button class="add-q-btn" onclick="addQ('multiple')">🔘 Multiple choice</button>
      <button class="add-q-btn" onclick="addQ('checkbox')">☑️ Checkboxes</button>
      <button class="add-q-btn" onclick="addQ('dropdown')">🔽 Dropdown</button>
      <button class="add-q-btn" onclick="addQ('rating')">⭐ Star rating</button>
      <button class="add-q-btn" onclick="addQ('scale')">📊 Scale 1–10</button>
    </div>
  </div>

  <div class="save-bar">
    <a href="/surveys/custom" class="btn">Cancel</a>
    <button class="btn btn-green" onclick="saveSurvey()">
      <%= survey ? '💾 Update Survey' : '🚀 Save & Publish' %>
    </button>
  </div>
</div>

<div id="toast"></div>

<!-- Preview Modal -->
<div id="preview-backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:none;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:14px;padding:2rem;max-width:560px;width:90%;max-height:85vh;overflow-y:auto;position:relative;">
    <button onclick="document.getElementById('preview-backdrop').style.display='none'" style="position:absolute;top:14px;right:14px;background:none;border:none;font-size:20px;cursor:pointer;">✕</button>
    <div id="preview-content"></div>
  </div>
</div>

<script>
  const SURVEY_ID = <%- survey ? survey.id : 'null' %>;
  const typeLabels = { short:'Short text', long:'Long text', multiple:'Multiple choice', checkbox:'Checkboxes', dropdown:'Dropdown', rating:'Star rating', scale:'Scale 1–10' };

  let questions = <%- survey ? JSON.stringify(survey.questions.map(q => ({ id: q.id, tempId: q.id, type: q.type, label: q.label, required: q.required, choices: q.choices || [] }))) : '[]' %>;
  let nextTempId = 1000;
  let dragSrc = null;

  function render() {
    const list = document.getElementById('questions-list');
    if (!questions.length) {
      list.innerHTML = '<div class="empty-state">No questions yet. Add one above ☝️</div>';
      return;
    }
    list.innerHTML = questions.map((q, i) => buildCard(q, i)).join('');
    list.querySelectorAll('.q-card').forEach(el => {
      el.addEventListener('dragstart', e => { dragSrc = el; el.classList.add('dragging'); e.dataTransfer.setData('text/plain', el.dataset.tid); });
      el.addEventListener('dragover',  e => { e.preventDefault(); el.classList.add('drag-over'); });
      el.addEventListener('dragleave', () => el.classList.remove('drag-over'));
      el.addEventListener('drop', e => {
        e.preventDefault(); el.classList.remove('drag-over');
        if (dragSrc === el) return;
        const fi = questions.findIndex(q => String(q.tempId) === dragSrc.dataset.tid);
        const ti = questions.findIndex(q => String(q.tempId) === el.dataset.tid);
        const [moved] = questions.splice(fi, 1);
        questions.splice(ti, 0, moved);
        render();
      });
      el.addEventListener('dragend', () => list.querySelectorAll('.q-card').forEach(c => c.classList.remove('dragging','drag-over')));
    });
  }

  function buildCard(q, i) {
    const choiceIcon = q.type === 'checkbox' ? '☑' : q.type === 'dropdown' ? '▸' : '◉';
    let body = '';
    if (q.type === 'short') body = '<div class="preview-box">Short answer</div>';
    else if (q.type === 'long') body = '<div class="preview-box tall">Long answer</div>';
    else if (['multiple','checkbox','dropdown'].includes(q.type)) {
      const rows = q.choices.map((c, ci) => `
        <div class="choice-row">
          <span class="choice-icon">${choiceIcon}</span>
          <input class="choice-inp" type="text" value="${escHtml(c)}" placeholder="Option ${ci+1}"
            onchange="updateChoice(${q.tempId},${ci},this.value)" />
          <button class="icon-btn del" onclick="removeChoice(${q.tempId},${ci})" title="Remove">✕</button>
        </div>`).join('');
      body = `<div class="choices-list">${rows}</div>
        <button class="add-choice" onclick="addChoice(${q.tempId})">＋ Add option</button>`;
    } else if (q.type === 'rating') {
      body = '<div class="rating-stars">★★★★★</div>';
    } else if (q.type === 'scale') {
      body = '<div class="scale-dots">' + Array.from({length:10},(_,k)=>`<div class="scale-dot">${k+1}</div>`).join('') + '</div>';
    }

    return `<div class="q-card" draggable="true" data-tid="${q.tempId}">
      <div class="q-row">
        <span class="drag-handle" title="Drag to reorder">⠿</span>
        <span class="q-num">Q${i+1}</span>
        <div class="q-body">
          <input class="q-label-inp" type="text" value="${escHtml(q.label)}" placeholder="Question text"
            onchange="updateLabel(${q.tempId},this.value)" />
          <div class="q-meta">
            <span class="type-badge">${typeLabels[q.type]}</span>
            <select class="type-sel" onchange="changeType(${q.tempId},this.value)">
              ${Object.entries(typeLabels).map(([v,l])=>`<option value="${v}"${q.type===v?' selected':''}>${l}</option>`).join('')}
            </select>
            <label class="req-label">
              <input type="checkbox" ${q.required?'checked':''} onchange="toggleReq(${q.tempId},this.checked)" />
              Required
            </label>
          </div>
          ${body}
        </div>
        <div class="q-ctrls">
          <button class="icon-btn" onclick="dupQ(${q.tempId})" title="Duplicate">⧉</button>
          <button class="icon-btn del" onclick="delQ(${q.tempId})" title="Delete">🗑</button>
        </div>
      </div>
    </div>`;
  }

  function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function addQ(type) {
    const defaults = { short:[],long:[],multiple:['Option 1','Option 2'],checkbox:['Option 1','Option 2'],dropdown:['Option 1','Option 2'],rating:[],scale:[] };
    questions.push({ tempId: nextTempId++, type, label:'', required:false, choices:[...defaults[type]] });
    render();
    setTimeout(()=>{ const ins=document.querySelectorAll('.q-label-inp'); if(ins.length) ins[ins.length-1].focus(); }, 50);
  }
  function delQ(tid) { questions = questions.filter(q=>q.tempId!==tid); render(); }
  function dupQ(tid) {
    const q=questions.find(q=>q.tempId===tid), idx=questions.findIndex(q=>q.tempId===tid);
    questions.splice(idx+1,0,{...q,tempId:nextTempId++,id:undefined,choices:[...q.choices],label:q.label+' (copy)'});
    render();
  }
  function updateLabel(tid,v) { questions.find(q=>q.tempId===tid).label=v; }
  function changeType(tid,type) {
    const q=questions.find(q=>q.tempId===tid); q.type=type;
    if(['multiple','checkbox','dropdown'].includes(type)&&!q.choices.length) q.choices=['Option 1','Option 2'];
    render();
  }
  function toggleReq(tid,v) { questions.find(q=>q.tempId===tid).required=v; }
  function addChoice(tid) { questions.find(q=>q.tempId===tid).choices.push(''); render(); }
  function updateChoice(tid,ci,v) { questions.find(q=>q.tempId===tid).choices[ci]=v; }
  function removeChoice(tid,ci) { const q=questions.find(q=>q.tempId===tid); q.choices.splice(ci,1); render(); }

  function showToast(msg, ok=true) {
    const t=document.getElementById('toast');
    t.textContent=msg; t.style.background=ok?'#2d7a3a':'#e53e3e'; t.style.display='block';
    setTimeout(()=>t.style.display='none', 3000);
  }

  async function saveSurvey() {
    const title = document.getElementById('form-title').value.trim();
    if (!title) return showToast('Please enter a survey title', false);
    if (!questions.length) return showToast('Add at least one question', false);

    const payload = {
      title,
      description: document.getElementById('form-desc').value.trim(),
      questions: questions.map((q,i) => ({ order:i+1, type:q.type, label:q.label||'Untitled question', required:q.required, choices:q.choices })),
    };

    const url    = SURVEY_ID ? `/surveys/custom/${SURVEY_ID}` : '/surveys/custom';
    const method = SURVEY_ID ? 'PUT' : 'POST';

    try {
      const res  = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
      const data = await res.json();
      if (data.success) {
        showToast(SURVEY_ID ? 'Survey updated!' : 'Survey saved!');
        setTimeout(()=>window.location='/surveys/custom', 1200);
      } else showToast(data.message||'Error saving', false);
    } catch(e) { showToast('Network error', false); }
  }

  function openPreview() {
    const title = document.getElementById('form-title').value || 'Untitled Survey';
    const desc  = document.getElementById('form-desc').value;
    let html = `<h2 style="font-size:1.3rem;font-weight:700;color:#2d7a3a;margin-bottom:4px;">${escHtml(title)}</h2>
      <p style="color:#666;font-size:14px;margin-bottom:1.5rem;">${escHtml(desc)}</p>`;
    questions.forEach((q,i) => {
      const req = q.required ? '<span style="color:#e53e3e;margin-left:2px;">*</span>' : '';
      html += `<div style="margin-bottom:1.2rem;">
        <div style="font-size:14px;font-weight:600;margin-bottom:7px;">${i+1}. ${escHtml(q.label||'Untitled')}${req}</div>`;
      if(q.type==='short') html+=`<input style="width:100%;border:1px solid #ddd;border-radius:7px;padding:7px 12px;font-size:14px;outline:none;" placeholder="Your answer" />`;
      else if(q.type==='long') html+=`<textarea style="width:100%;border:1px solid #ddd;border-radius:7px;padding:7px 12px;font-size:14px;outline:none;resize:vertical;min-height:70px;" placeholder="Your answer"></textarea>`;
      else if(q.type==='multiple') html+=q.choices.map(c=>`<label style="display:flex;align-items:center;gap:8px;font-size:14px;margin-bottom:6px;cursor:pointer;"><input type="radio" name="pq${i}" style="accent-color:#2d7a3a;"> ${escHtml(c)}</label>`).join('');
      else if(q.type==='checkbox') html+=q.choices.map(c=>`<label style="display:flex;align-items:center;gap:8px;font-size:14px;margin-bottom:6px;cursor:pointer;"><input type="checkbox" style="accent-color:#2d7a3a;"> ${escHtml(c)}</label>`).join('');
      else if(q.type==='dropdown') html+=`<select style="border:1px solid #ddd;border-radius:7px;padding:7px 12px;font-size:14px;width:100%;"><option>Choose...</option>${q.choices.map(c=>`<option>${escHtml(c)}</option>`).join('')}</select>`;
      else if(q.type==='rating') html+=`<div style="font-size:28px;color:#e2c94b;letter-spacing:3px;cursor:pointer;">★★★★★</div>`;
      else if(q.type==='scale') html+=`<div style="display:flex;gap:5px;flex-wrap:wrap;">${Array.from({length:10},(_,k)=>`<button style="width:34px;height:34px;border-radius:50%;border:1px solid #ddd;background:#fafafa;cursor:pointer;font-size:13px;">${k+1}</button>`).join('')}</div>`;
      html += '</div>';
    });
    html += `<button style="width:100%;padding:10px;border-radius:8px;background:#2d7a3a;color:#fff;border:none;font-size:15px;cursor:pointer;margin-top:.5rem;">Submit</button>`;
    document.getElementById('preview-content').innerHTML = html;
    document.getElementById('preview-backdrop').style.display = 'flex';
  }

  render();
</script>

<%- include('../partials/footer') %>