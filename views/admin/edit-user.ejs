<%- include('../partials/header') %>

<div class="dashboard-container">
  <div class="page-header">
    <h1>✏️ Edit User</h1>
    <a href="/admin/users" class="btn-back">← Back to Users</a>
  </div>

  <div class="section-card" style="max-width: 600px;">
    <form action="/admin/users/<%= editUser.id %>?_method=PUT" method="POST" novalidate>
      <div class="form-group">
        <label>Full Name <span class="required">*</span></label>
        <input type="text" name="name" value="<%= editUser.name %>" required />
      </div>
      <div class="form-group">
        <label>Email Address <span class="required">*</span></label>
        <input type="email" name="email" value="<%= editUser.email %>" required />
      </div>
      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone" value="<%= editUser.phone || '' %>" placeholder="+63 9XX XXX XXXX" />
      </div>
      <div class="form-group">
        <label>Address</label>
        <input type="text" name="address" value="<%= editUser.address || '' %>" />
      </div>
      <div class="form-group">
        <label>Role <span class="required">*</span></label>
        <select name="role" required>
          <option value="STUDENT" <%= editUser.role === 'STUDENT' ? 'selected' : '' %>>STUDENT</option>
          <option value="TEACHER" <%= editUser.role === 'TEACHER' ? 'selected' : '' %>>TEACHER</option>
          <option value="ADMIN" <%= editUser.role === 'ADMIN' ? 'selected' : '' %>>ADMIN</option>
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary">Save Changes</button>
        <a href="/admin/users" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
