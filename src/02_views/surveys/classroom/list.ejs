<div class="card-container">
  <div class="card-header">
    <h1>Classroom Surveys</h1>
  </div>

  <% if (classrooms.length === 0) { %>
    <div class="empty-state"><p>No surveys available yet.</p></div>
  <% } %>

  <% classrooms.forEach(classroom => { %>
    <% if (classroom.surveys.length > 0) { %>
      <div style="font-size: 1.4em; font-weight: bold; margin-top: 1.5em;">
        <%= classroom.name %>
        <span style="font-size: 0.7em; font-weight: normal;">— <%= classroom.teacher.name %></span>
      </div>
      <hr>
      <div class="grid-survey">
        <% classroom.surveys.forEach(survey => { %>
          <div class="survey-card">
            <div class="survey-card-header">
              <h3><%= survey.title %></h3>
            </div>
            <div class="survey-card-body">
              <span>Created <%= new Date(survey.createdAt).toLocaleDateString() %></span>
            </div>
            <div class="survey-card-footer">
              <a class="btn btn-primary" href="/classroom-survey/<%= survey.id %>">Take Survey</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>