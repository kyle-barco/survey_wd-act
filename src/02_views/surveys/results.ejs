<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"> 
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - <%= survey.title %></title>
  <link rel="stylesheet" href="/style.css"> <!-- Link your CSS here -->
</head>
<body>
  <div class="results-container">
    <header class="results-header">
      <h1><%= survey.title %> — Results</h1>
      <div class="meta-info">
        <p><strong>Classroom:</strong> <%= survey.classroom.name %></p>
        <p><strong>Total Responses:</strong> <%= survey.responses.length %></p>
      </div>
    </header>

    <div class="table-responsive">
      <table class="results-table">
        <thead>
          <tr>
            <th>Student</th>
            <th>Grade/Class</th>
            <th>Subject</th>
            <th>Rating</th>
            <th>Favorite Lesson</th>
            <th>Suggestions</th>
          </tr>
        </thead>
        <tbody>
          <% survey.responses.forEach(response => { %>
            <tr>
              <!-- Handles anonymous responses based on your schema's "anonymous" boolean -->
              <td class="font-bold">
                <%= response.anonymous || !response.student ? "Anonymous" : response.student.name %>
              </td>
              <td><%= response.grade %></td>
              <td><%= response.subject %></td>
              <td>
                <span class="score-badge"><%= response.rating %>/5</span>
              </td>
              <td class="text-small"><%= response.favoriteLesson || "—" %></td>
              <td class="text-small"><%= response.suggestions || "—" %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="actions">
      <a href="/" class="btn-back">Back to Dashboard</a>
    </div>
  </div>
</body>
</html>