<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - <%= survey.title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="dresults-container">

    <header class="dresults-header">
      <div class="dresults-header__top">
        <h1 class="dresults-title"><%= survey.title %></h1>
        <span class="disaster-badge disaster-badge--<%= survey.category.toLowerCase() %>">
          <%= survey.category.replace(/_/g, ' ') %>
        </span>
      </div>
      <div class="dresults-meta">
        <div class="dresults-meta__item">
          <span class="dresults-meta__label">Total Responses</span>
          <span class="dresults-meta__value"><%= survey.responses.length %></span>
        </div>
        <div class="dresults-meta__item">
          <span class="dresults-meta__label">Created</span>
          <span class="dresults-meta__value"><%= new Date(survey.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
        <div class="dresults-meta__item">
          <span class="dresults-meta__label">Admin</span>
          <span class="dresults-meta__value"><%= survey.admin.name %></span>
        </div>
      </div>
    </header>

    <% if (survey.responses.length === 0) { %>
      <div class="dresults-empty">
        <p>No responses submitted yet.</p>
        <a href="/" class="dresults-btn dresults-btn--ghost">Back to Dashboard</a>
      </div>

    <% } else { %>

      <%# ── Household Readiness Results ── %>
      <% if (survey.category === 'HOUSEHOLD_READINESS') { %>
      <div class="dresults-section">
        <div class="dresults-section__title">Household Readiness</div>
        <div class="table-responsive">
          <table class="dresults-table">
            <thead>
              <tr>
                <th>Respondent</th>
                <th>Household Size</th>
                <th>Has Emergency Plan</th>
                <th>Practice Frequency</th>
                <th>Aware of Alerts</th>
              </tr>
            </thead>
            <tbody>
              <% survey.responses.forEach(r => { %>
                <tr>
                  <td class="dresults-table__name"><%= r.respondent ? r.respondent.name : 'Anonymous' %></td>
                  <td><%= r.householdSize ?? '—' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasEmergencyPlan ? 'yes' : 'no' %>">
                      <%= r.hasEmergencyPlan ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td><%= r.planPracticeFreq ?? '—' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.awareCommunityAlerts ? 'yes' : 'no' %>">
                      <%= r.awareCommunityAlerts ? 'Yes' : 'No' %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <%# ── Emergency Supplies Results ── %>
      <% if (survey.category === 'EMERGENCY_SUPPLIES') { %>
      <div class="dresults-section">
        <div class="dresults-section__title">Emergency Supplies</div>
        <div class="table-responsive">
          <table class="dresults-table">
            <thead>
              <tr>
                <th>Respondent</th>
                <th>Go-Bag</th>
                <th>Water (days)</th>
                <th>Food (days)</th>
                <th>First Aid Kit</th>
                <th>Flashlight</th>
                <th>Battery Radio</th>
              </tr>
            </thead>
            <tbody>
              <% survey.responses.forEach(r => { %>
                <tr>
                  <td class="dresults-table__name"><%= r.respondent ? r.respondent.name : 'Anonymous' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasGoBag ? 'yes' : 'no' %>">
                      <%= r.hasGoBag ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td><%= r.waterSupplyDays ?? '—' %></td>
                  <td><%= r.foodSupplyDays ?? '—' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasFirstAidKit ? 'yes' : 'no' %>">
                      <%= r.hasFirstAidKit ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasFlashlight ? 'yes' : 'no' %>">
                      <%= r.hasFlashlight ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasBatteryRadio ? 'yes' : 'no' %>">
                      <%= r.hasBatteryRadio ? 'Yes' : 'No' %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <%# ── Evacuation Planning Results ── %>
      <% if (survey.category === 'EVACUATION_PLANNING') { %>
      <div class="dresults-section">
        <div class="dresults-section__title">Evacuation Planning</div>
        <div class="table-responsive">
          <table class="dresults-table">
            <thead>
              <tr>
                <th>Respondent</th>
                <th>Knows Route</th>
                <th>Meeting Point</th>
                <th>Practiced Drill</th>
                <th>Drill Frequency</th>
                <th>Knows Shelter</th>
              </tr>
            </thead>
            <tbody>
              <% survey.responses.forEach(r => { %>
                <tr>
                  <td class="dresults-table__name"><%= r.respondent ? r.respondent.name : 'Anonymous' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.knowsEvacuationRoute ? 'yes' : 'no' %>">
                      <%= r.knowsEvacuationRoute ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.hasDesignatedMeetingPoint ? 'yes' : 'no' %>">
                      <%= r.hasDesignatedMeetingPoint ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.practisedEvacuation ? 'yes' : 'no' %>">
                      <%= r.practisedEvacuation ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td><%= r.evacPracticeFreq ?? '—' %></td>
                  <td>
                    <span class="dresults-bool dresults-bool--<%= r.knowsLocalShelter ? 'yes' : 'no' %>">
                      <%= r.knowsLocalShelter ? 'Yes' : 'No' %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <%# ── General Responses ── %>
      <div class="dresults-section">
        <div class="dresults-section__title">General Responses</div>
        <div class="dresults-general-list">
          <% survey.responses.forEach((r, i) => { %>
            <% if (r.biggestConcern || r.additionalComments) { %>
            <div class="dresults-general-item">
              <div class="dresults-general-item__name">
                <%= r.respondent ? r.respondent.name : 'Anonymous' %>
              </div>
              <% if (r.biggestConcern) { %>
                <div class="dresults-general-item__field">
                  <span class="dresults-general-item__label">Biggest Concern</span>
                  <span class="dresults-general-item__text"><%= r.biggestConcern %></span>
                </div>
              <% } %>
              <% if (r.additionalComments) { %>
                <div class="dresults-general-item__field">
                  <span class="dresults-general-item__label">Additional Comments</span>
                  <span class="dresults-general-item__text"><%= r.additionalComments %></span>
                </div>
              <% } %>
            </div>
            <% } %>
          <% }) %>
        </div>
      </div>

    <% } %>

    <div class="dresults-actions">
      <a href="/" class="dresults-btn dresults-btn--ghost">Back to Dashboard</a>
    </div>

  </div>
</body>
</html>