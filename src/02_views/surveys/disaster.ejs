<div class="disaster-container">
  <div class="disaster-header">
    <h1><%= survey.title %></h1>
    <span class="disaster-badge disaster-badge--<%= survey.category.toLowerCase() %>">
      <%= survey.category.replace(/_/g, ' ') %>
    </span>
  </div>

  <form action="/disaster-survey/<%= survey.id %>/respond" method="POST">

    <% if (survey.category === 'HOUSEHOLD_READINESS') { %>
    <div class="disaster-section">
      <div class="disaster-section__title">Household Readiness</div>

      <div class="disaster-field">
        <label class="disaster-label" for="householdSize">How many people live in your household?</label>
        <input type="number" id="householdSize" name="householdSize" min="1" max="20" class="disaster-input" required>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Does your household have an emergency plan?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasEmergencyPlan" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasEmergencyPlan" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label" for="planPracticeFreq">How often does your household practice the emergency plan?</label>
        <select id="planPracticeFreq" name="planPracticeFreq" class="disaster-input">
          <option value="">-- Select --</option>
          <option value="never">Never</option>
          <option value="rarely">Rarely</option>
          <option value="sometimes">Sometimes</option>
          <option value="regularly">Regularly</option>
        </select>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Are you aware of your community's disaster alert system?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="awareCommunityAlerts" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="awareCommunityAlerts" value="false"> No</label>
        </div>
      </div>
    </div>
    <% } %>

    <% if (survey.category === 'EMERGENCY_SUPPLIES') { %>
    <div class="disaster-section">
      <div class="disaster-section__title">Emergency Supplies</div>

      <div class="disaster-field">
        <label class="disaster-label">Do you have a go-bag ready?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasGoBag" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasGoBag" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label" for="waterSupplyDays">How many days of water supply do you have?</label>
        <input type="number" id="waterSupplyDays" name="waterSupplyDays" min="0" class="disaster-input" required>
      </div>

      <div class="disaster-field">
        <label class="disaster-label" for="foodSupplyDays">How many days of food supply do you have?</label>
        <input type="number" id="foodSupplyDays" name="foodSupplyDays" min="0" class="disaster-input" required>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Do you have a first aid kit?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasFirstAidKit" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasFirstAidKit" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Do you have a flashlight with working batteries?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasFlashlight" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasFlashlight" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Do you have a battery-powered radio?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasBatteryRadio" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasBatteryRadio" value="false"> No</label>
        </div>
      </div>
    </div>
    <% } %>

    <% if (survey.category === 'EVACUATION_PLANNING') { %>
    <div class="disaster-section">
      <div class="disaster-section__title">Evacuation Planning</div>

      <div class="disaster-field">
        <label class="disaster-label">Do you know your evacuation route?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="knowsEvacuationRoute" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="knowsEvacuationRoute" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Do you have a designated meeting point for your household?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="hasDesignatedMeetingPoint" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="hasDesignatedMeetingPoint" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Have you ever practiced an evacuation drill?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="practisedEvacuation" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="practisedEvacuation" value="false"> No</label>
        </div>
      </div>

      <div class="disaster-field">
        <label class="disaster-label" for="evacPracticeFreq">How often do you practice evacuation drills?</label>
        <select id="evacPracticeFreq" name="evacPracticeFreq" class="disaster-input">
          <option value="">-- Select --</option>
          <option value="never">Never</option>
          <option value="once">Once</option>
          <option value="annually">Annually</option>
          <option value="biannually">Biannually</option>
        </select>
      </div>

      <div class="disaster-field">
        <label class="disaster-label">Do you know the location of your nearest evacuation shelter?</label>
        <div class="disaster-radio-group">
          <label class="disaster-radio-option"><input type="radio" name="knowsLocalShelter" value="true" required> Yes</label>
          <label class="disaster-radio-option"><input type="radio" name="knowsLocalShelter" value="false"> No</label>
        </div>
      </div>
    </div>
    <% } %>

    <%# ── General ── %>
    <div class="disaster-section disaster-section--general">
      <div class="disaster-section__title">General</div>

      <div class="disaster-field">
        <label class="disaster-label" for="biggestConcern">What is your biggest concern during a disaster?</label>
        <textarea id="biggestConcern" name="biggestConcern" class="disaster-input disaster-textarea" rows="3" placeholder="e.g. Safety of family members, lack of supplies..."></textarea>
      </div>

      <div class="disaster-field">
        <label class="disaster-label" for="additionalComments">Any additional comments or suggestions?</label>
        <textarea id="additionalComments" name="additionalComments" class="disaster-input disaster-textarea" rows="3" placeholder="Optional"></textarea>
      </div>
    </div>

    <div class="disaster-footer">
      <button type="submit" class="disaster-btn disaster-btn--primary">Submit Response</button>
      <a href="/" class="disaster-btn disaster-btn--ghost">Cancel</a>
    </div>

  </form>
</div>