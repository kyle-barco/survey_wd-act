<style>
/* ── Layout Dashboard ── */
.cl-container {
  max-width: 800px;
  margin: 2rem auto;
  padding: 0 1rem 4rem;
  font-family: var(--font-sans, sans-serif);
}

.cl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 0.5px solid var(--color-border-tertiary);
}

.cl-title {
  font-size: 24px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0;
}

.cl-subtitle {
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-top: 4px;
}

/* ── Grid List Layout ── */
.cl-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* ── Survey Row Cards ── */
.cl-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-background-primary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: var(--border-radius-lg);
  padding: 1.25rem;
  transition: border-color 0.2s, transform 0.15s;
}

.cl-card:hover {
  border-color: var(--color-border-secondary);
}

.cl-card__info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cl-card__title {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin: 0;
}

.cl-card__meta {
  font-size: 12px;
  color: var(--color-text-tertiary);
}

/* ── Actions Matrix Group ── */
.cl-actions {
  display: flex;
  gap: 8px;
}

/* ── UI Buttons ── */
.cl-btn {
  padding: 8px 16px;
  border-radius: var(--border-radius-md);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: background 0.15s;
}

.cl-btn--primary {
  background: #7f77dd;
  color: #fff;
  border: none;
}

.cl-btn--primary:hover {
  background: #534ab7;
}

.cl-btn--ghost {
  background: transparent;
  color: var(--color-text-secondary);
  border: 0.5px solid var(--color-border-secondary);
}

.cl-btn--ghost:hover {
  background: var(--color-background-secondary);
}

/* ── Empty State Dashboard Pattern ── */
.cl-empty {
  text-align: center;
  padding: 4rem 2rem;
  border: 0.5px dashed var(--color-border-secondary);
  border-radius: var(--border-radius-lg);
  background: var(--color-background-secondary);
}

.cl-empty__title {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.cl-empty__text {
  font-size: 13px;
  color: var(--color-text-tertiary);
  margin-bottom: 1.5rem;
}

@media (max-width: 520px) {
  .cl-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .cl-card {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .cl-actions {
    width: 100%;
  }
  .cl-btn {
    flex: 1;
    justify-content: center;
  }
}
</style>

<div class="cl-container">
  <div class="cl-header">
    <div>
      <h1 class="cl-title">Custom Surveys</h1>
      <p class="cl-subtitle">Manage, take, or view analytical results for active dynamic questionnaires.</p>
    </div>
    <a href="/custom-survey/new" class="cl-btn cl-btn--primary">+ Create New Survey</a>
  </div>

  <% if (surveys && surveys.length > 0) { %>
    <div class="cl-grid">
      <% surveys.forEach((survey) => { %>
        <div class="cl-card">
          <div class="cl-card__info">
            <h2 class="cl-card__title"><%= survey.title %></h2>
            <div class="cl-card__meta">
              <span><%= survey.questions ? survey.questions.length : 0 %> Questions</span>
              <% if (survey._count && survey._count.responses !== undefined) { %>
                &bull; <span><%= survey._count.responses %> Responses Submitted</span>
              <% } %>
            </div>
          </div>
          
          <div class="cl-actions">
            <a href="/custom-survey/<%= survey.id %>" class="cl-btn cl-btn--primary">Take Survey</a>
            <a href="/custom-survey/<%= survey.id %>/results" class="cl-btn cl-btn--ghost">View Results</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="cl-empty">
      <div class="cl-empty__title">No Surveys Found</div>
      <p class="cl-empty__text">There are currently no custom surveys configured inside the global cluster environment database.</p>
      <a href="/custom-survey/new" class="cl-btn cl-btn--primary">Get Started</a>
    </div>
  <% } %>
</div>