<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register</title>
    </head>

  <body>
    <h1>Register Now!</h1>
    <form action="/register" method="POST" class="register-form">
      
      <div class="input-group">
        <label for="name">Name</label>
        <input type="text" name="name" id="name" required />
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'name') %>
          <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
        <% } %>
      </div>

      <div class="input-group">
        <label for="email">Email</label>
        <input type="email" name="email" id="email" required />
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'email') %>
          <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
        <% } %>
      </div>

<div class="input-group">
<label for="birthday">Date of Birth</label>
  <input type="date" name="birthday" id="birthday" required />
  <% if (locals.errors) { %>
    <% const err = errors.find(e => e.path === 'birthday') %>
    <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
  <% } %>
</div>

      <div class="input-group">
        <label for="gender">Gender</label>
        <select name="gender" id="gender" required>
          <option value="">Select gender</option>
          <option value="MALE">Male</option>
          <option value="FEMALE">Female</option>
          <option value="OTHER">Other / Prefer not to say</option>
        </select>
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'gender') %>
          <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
        <% } %>
      </div>

      <div class="input-group">
        <label for="role">Role</label>
        <select name="role" id="role" required>
          <option value="">Select a role</option>
          <option value="STUDENT">Student</option>
          <option value="TEACHER">Teacher</option>
        </select>
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'role') %>
          <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
        <% } %>
      </div>

      <div class="input-group">
        <label for="institution">School / Institution</label>
        <input type="text" name="institution" id="institution" placeholder="e.g., University Name or School Branch" />
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'institution') %>
          <% if (err) { %><span style="color:red"><%= err.msg %></span><% } %>
        <% } %>
      </div>

      <div class="input-group " style="position: relative;">
        <label for="password">Password</label>
        <input type="password" name="password" id="password" style="padding-right: 2.5rem;" />
        <button class="btn-password" type="button" onclick="
          const input = document.getElementById('password');
          const isHidden = input.type === 'password';
          input.type = isHidden ? 'text' : 'password';
          document.getElementById('eye-open').style.display = isHidden ? 'none' : 'block';
          document.getElementById('eye-closed').style.display = isHidden ? 'block' : 'none';
        ">
          <svg id="eye-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <svg id="eye-closed" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21" />
          </svg>
        </button>
        <% if (locals.errors) { %>
          <% const err = errors.find(e => e.path === 'password') %>
          <% if (err) { %><span style="color:red; display:block; margin-top:4px"><%= err.msg %></span><% } %>
        <% } %>
      </div>

      <button type="submit">Register!</button>
      
      <div class="login">
        <span>Already have an account?</span>
        <a href="/login" class="login-btn">Login</a>
      </div>
    </form>
  </body>
  <script>
const birthdayInput = document.getElementById('birthday');
  const today = new Date();
  
  const currentMonth = String(today.getMonth() + 1).padStart(2, '0');
  const currentDay = String(today.getDate()).padStart(2, '0');

  // 1. Upper Age Limit: Max 120 years old (Oldest date allowed)
  const minYear = today.getFullYear() - 120;
  birthdayInput.min = `${minYear}-${currentMonth}-${currentDay}`;
  
  // 2. Lower Age Limit: Min 122 years old (Youngest date allowed)
  const maxYear = today.getFullYear() - 12;
  birthdayInput.max = `${maxYear}-${currentMonth}-${currentDay}`;
  </script>
</html>