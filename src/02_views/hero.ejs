<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Echo — Hear Every Voice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* ── Mirror global palette exactly ── */
      :root {
        --navy-900: #0f1e35;
        --navy-800: #1a2f4e;
        --navy-700: #1e3a61;
        --navy-600: #244576;
        --navy-400: #3a6494;
        --navy-200: #a8bee0;
        --navy-100: #d4e2f0;
        --navy-50: #edf3f9;

        --gray-900: #1e1e1e;
        --gray-700: #3c3c3c;
        --gray-500: #6b6b6b;
        --gray-300: #b0b0b0;
        --gray-200: #d6d6d6;
        --gray-100: #eeeeee;
        --gray-50: #f7f7f7;

        --white: #ffffff;
        --header-height: 64px;
      }

    [data-theme="dark"] {
      --navy-900: #d4e2f0;
      --navy-800: #a8bee0;
      --navy-700: #7aaad4;
      --navy-600: #5a8cb8;
      --navy-400: #4a7aaa;
      --navy-200: #2a4a6e;
      --navy-100: #1a3050;
      --navy-50:  #0d1f35;

      --gray-900: #f0f0f0;
      --gray-700: #c8c8c8;
      --gray-500: #9a9a9a;
      --gray-300: #5a5a5a;
      --gray-200: #3a3a3a;
      --gray-100: #2a2a2a;
      --gray-50:  #1e1e1e;
      --white:    #1a1a2e;
    }

      html,
      body {
        height: 100%;
        background: var(--gray-50);
        color: var(--gray-900);
        font-family: "Archivo", sans-serif;
        font-optical-sizing: auto;
        overflow-x: hidden;
         transition: background 0.25s, color 0.25s;
      }

      /* ── Nav ── */
      .hero-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        height: var(--header-height);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2.5rem;
        background: var(--white);
        border-bottom: 1px solid var(--gray-200);
        transition: box-shadow 0.2s;
      }
      .hero-nav.scrolled {
        box-shadow: 0 2px 12px rgba(15, 30, 53, 0.08);
      }

      .nav-logo {
        display: flex;
        align-items: center;
        text-decoration: none;
      }
      .nav-logo-text {
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--navy-700);
      }
      .nav-logo img {
        height: 50px;
        width: auto;
        display: block;
      }
      .nav-logo-dot {
        color: var(--navy-400);
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      /* ── Buttons — mirrors global .btn exactly ── */
      .btn {
        display: inline-block;
        font-family: "Archivo", sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 0.7rem 1.5rem;
        border-radius: 6px;
        border: 1px solid var(--navy-700);
        cursor: pointer;
        transition:
          background 0.15s,
          border-color 0.15s,
          color 0.15s;
        white-space: nowrap;
      }
      .btn-primary {
        background: var(--navy-700);
        color: var(--white);
      }
      .btn-primary:hover {
        background: var(--navy-900);
        border-color: var(--navy-900);
      }
      .btn-ghost {
        background: transparent;
        color: var(--navy-700);
        border-color: var(--gray-200);
      }
      .btn-ghost:hover {
        background: var(--navy-50);
        border-color: var(--navy-200);
        color: var(--navy-900);
      }
      .btn-lg {
        padding: 0.85rem 2rem;
        font-size: 0.88rem;
      }

      /* ── Page wrapper ── */
      .page {
        padding-top: var(--header-height);
      }

      /* ── Hero Section ── */
      .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 4rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 6rem 2.5rem 5rem;
        min-height: calc(100vh - var(--header-height));
      }

      .hero-text {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--navy-400);
        opacity: 0;
        animation: fadeUp 0.6s 0.1s forwards;
      }
      .hero-eyebrow::before {
        content: "";
        display: block;
        width: 24px;
        height: 2px;
        background: var(--navy-400);
        border-radius: 2px;
      }

      .hero-headline {
        font-size: clamp(2.6rem, 4.5vw, 4.25rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.03em;
        color: var(--navy-900);
        opacity: 0;
        animation: fadeUp 0.7s 0.25s forwards;
      }
      .hero-headline em {
        font-style: italic;
        font-weight: 400;
        color: var(--navy-400);
      }

      .hero-sub {
        font-size: 1rem;
        line-height: 1.75;
        color: var(--gray-500);
        max-width: 38ch;
        opacity: 0;
        animation: fadeUp 0.7s 0.4s forwards;
      }

      .hero-cta {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeUp 0.7s 0.55s forwards;
      }

      .hero-note {
        font-size: 0.75rem;
        color: var(--gray-300);
        letter-spacing: 0.04em;
      }

      /* ── Hero Visual (mock survey card) ── */
      .hero-visual {
        position: relative;
        opacity: 0;
        animation: fadeIn 0.9s 0.4s forwards;
      }

      .visual-frame {
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: 10px;
        padding: 1.75rem;
        box-shadow:
          0 4px 24px rgba(15, 30, 53, 0.1),
          0 1px 4px rgba(15, 30, 53, 0.06);
        position: relative;
      }

      .visual-tag {
        position: absolute;
        top: -0.75rem;
        left: 1.25rem;
        background: var(--navy-700);
        color: var(--white);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 0.25rem 0.7rem;
        border-radius: 4px;
      }

      .visual-survey-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--navy-900);
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--gray-100);
        letter-spacing: -0.01em;
      }

      .visual-question {
        font-size: 0.82rem;
        color: var(--gray-500);
        margin-bottom: 0.75rem;
        letter-spacing: 0.02em;
      }

      .visual-options {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        margin-bottom: 1.25rem;
      }

      .visual-option {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.55rem 0.8rem;
        border: 1px solid var(--gray-200);
        border-radius: 6px;
        font-size: 0.82rem;
        color: var(--gray-700);
        cursor: default;
        transition: border-color 0.15s;
      }
      .visual-option.selected {
        border-color: var(--navy-400);
        background: var(--navy-50);
        color: var(--navy-800);
        font-weight: 500;
      }
      .visual-option-dot {
        width: 13px;
        height: 13px;
        border-radius: 50%;
        border: 1.5px solid var(--gray-200);
        flex-shrink: 0;
      }
      .visual-option.selected .visual-option-dot {
        background: var(--navy-700);
        border-color: var(--navy-700);
      }

      .visual-bar-section {
        margin-top: 0.25rem;
      }
      .visual-bar-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.72rem;
        color: var(--gray-500);
        margin-bottom: 0.28rem;
        letter-spacing: 0.02em;
      }
      .visual-bar-track {
        height: 5px;
        background: var(--gray-100);
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 0.55rem;
      }
      .visual-bar-fill {
        height: 100%;
        background: var(--navy-600);
        border-radius: 99px;
        transform-origin: left;
        animation: growBar 1s ease-out both;
      }
      @keyframes growBar {
        from {
          transform: scaleX(0);
        }
        to {
          transform: scaleX(1);
        }
      }

      /* floating chips */
      .chip {
        position: absolute;
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: 6px;
        padding: 0.45rem 0.85rem;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--navy-700);
        box-shadow: 0 2px 8px rgba(15, 30, 53, 0.08);
        white-space: nowrap;
        letter-spacing: 0.02em;
      }
      .chip-1 {
        top: -1.25rem;
        right: 1.75rem;
        animation: float 3s ease-in-out infinite;
      }
      .chip-2 {
        bottom: 0.75rem;
        right: -1.25rem;
        animation: float 3.4s 0.5s ease-in-out infinite;
      }
      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-5px);
        }
      }

      /* ── Divider ── */
      .section-divider {
        border: none;
        border-top: 1px solid var(--gray-200);
        max-width: 1200px;
        margin: 0 auto;
      }

      /* ── Features ── */
      .features {
        max-width: 1200px;
        margin: 0 auto;
        padding: 5rem 2.5rem;
      }

      .features-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 3rem;
      }
      .features-header h2 {
        font-size: clamp(1.4rem, 2.2vw, 1.9rem);
        font-weight: 800;
        letter-spacing: -0.025em;
        color: var(--navy-900);
        white-space: nowrap;
      }
      .features-header-line {
        flex: 1;
        height: 1px;
        background: var(--gray-200);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border: 1px solid var(--gray-200);
        border-radius: 10px;
        overflow: hidden;
        background: var(--white);
      }

      .feature-cell {
        padding: 1.75rem 1.5rem;
        border-right: 1px solid var(--gray-200);
        border-bottom: 1px solid var(--gray-200);
        transition: background 0.15s;
      }
      .feature-cell:nth-child(3n) {
        border-right: none;
      }
      .feature-cell:nth-last-child(-n + 3) {
        border-bottom: none;
      }
      .feature-cell:hover {
        background: var(--navy-50);
      }

      .feature-icon {
        width: 36px;
        height: 36px;
        margin-bottom: 0.85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--navy-50);
        border: 1px solid var(--navy-100);
        border-radius: 6px;
        font-size: 1rem;
      }
      .feature-cell h3 {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--navy-900);
        margin-bottom: 0.4rem;
        letter-spacing: -0.01em;
      }
      .feature-cell p {
        font-size: 0.82rem;
        line-height: 1.65;
        color: var(--gray-500);
      }

      /* ── Quote strip ── */
      .quote-strip {
        background: var(--navy-900);
        color: var(--white);
        padding: 4rem 2.5rem;
        text-align: center;
      }
      .quote-strip blockquote {
        font-size: clamp(1.1rem, 2vw, 1.55rem);
        font-style: italic;
        font-weight: 300;
        max-width: 640px;
        margin: 0 auto 0.85rem;
        line-height: 1.55;
        color: var(--navy-100);
      }
      .quote-strip blockquote strong {
        font-weight: 700;
        color: var(--white);
        font-style: normal;
      }
      .quote-strip cite {
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--navy-400);
      }

      /* ── CTA Banner ── */
      .cta-banner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 5rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        flex-wrap: wrap;
      }
      .cta-banner h2 {
        font-size: clamp(1.5rem, 2.2vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.025em;
        color: var(--navy-900);
        max-width: 22ch;
        line-height: 1.2;
      }
      .cta-banner h2 em {
        font-style: italic;
        font-weight: 400;
        color: var(--navy-400);
      }
      .cta-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      /* ── Footer — matches global body > footer ── */
      .hero-footer {
        border-top: 1px solid var(--gray-200);
        background: var(--white);
        padding: 0 2.5rem;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .hero-footer span,
      .hero-footer a {
        font-size: 0.72rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--gray-300);
        text-decoration: none;
      }
      .hero-footer a:hover {
        color: var(--navy-400);
      }

      /* ── Animations ── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      /* ── Responsive ── */
      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
          padding: 4rem 1.5rem 3.5rem;
          min-height: auto;
          gap: 2.5rem;
        }
        .hero-visual {
          display: none;
        }
        .features {
          padding: 3rem 1.5rem;
        }
        .features-grid {
          grid-template-columns: 1fr 1fr;
        }
        .feature-cell:nth-child(2n) {
          border-right: none;
        }
        .feature-cell:nth-child(3n) {
          border-right: 1px solid var(--gray-200);
        }
        .cta-banner {
          padding: 3rem 1.5rem;
          flex-direction: column;
          align-items: flex-start;
        }
        .hero-nav {
          padding: 0 1.5rem;
        }
        .hero-footer {
          padding: 0 1.5rem;
        }
      }
      @media (max-width: 560px) {
        .features-grid {
          grid-template-columns: 1fr;
        }
        .feature-cell {
          border-right: none !important;
        }
        .feature-cell:nth-last-child(-n + 3) {
          border-bottom: 1px solid var(--gray-200);
        }
        .feature-cell:last-child {
          border-bottom: none;
        }
      }
    </style>
  </head>
  <body>
    <!-- ── Nav ── -->
    <nav class="hero-nav" id="heroNav">
      <a class="nav-logo" href="/">
        <img src="../../resources/img/echo_logo_svg.svg" alt="logo" />
        <!-- <span class="nav-logo-text">Ech<span class="nav-logo-dot">o</span></span> -->
      </a>
      <div class="nav-actions">
        <button
          class="btn btn-ghost"
          id="themeBtn"
          onclick="toggleTheme()"
          aria-label="Toggle dark mode"
        >
          <span id="themeIcon">🌙</span> 
        </button>
        <a href="/login" class="btn btn-ghost">Log in</a>
        <a href="/register" class="btn btn-primary">Get Started</a>
      </div>
    </nav>

    <div class="page">
      <!-- ── Hero ── -->
      <section class="hero">
        <div class="hero-text">
          <span class="hero-eyebrow">Survey &amp; Feedback Platform</span>
          <h1 class="hero-headline">
            Every voice<br /><em>deserves</em><br />to be heard.
          </h1>
          <p class="hero-sub">
            Echo brings classroom surveys and disaster preparedness assessments
            together in one place — built for teachers, trusted by students.
          </p>
          <div class="hero-cta">
            <a href="/register" class="btn btn-primary btn-lg"
              >Create an account</a
            >
            <a href="/login" class="btn btn-ghost btn-lg">Sign in</a>
          </div>
          <p class="hero-note">Free to join &mdash; no credit card required.</p>
        </div>

        <div class="hero-visual">
          <div class="chip chip-1">📋 12 responses</div>
          <div class="chip chip-2">✅ Survey live</div>

          <div class="visual-frame">
            <span class="visual-tag">Live Preview</span>
            <div class="visual-survey-title">
              End-of-Week Classroom Check-In
            </div>
            <p class="visual-question">
              How well did you understand today's lesson?
            </p>

            <div class="visual-options">
              <div class="visual-option">
                <span class="visual-option-dot"></span>Completely clear
              </div>
              <div class="visual-option selected">
                <span class="visual-option-dot"></span>Mostly understood
              </div>
              <div class="visual-option">
                <span class="visual-option-dot"></span>A bit confused
              </div>
              <div class="visual-option">
                <span class="visual-option-dot"></span>Very lost
              </div>
            </div>

            <div class="visual-bar-section">
              <div class="visual-bar-label">
                <span>Completely clear</span><span>42%</span>
              </div>
              <div class="visual-bar-track">
                <div class="visual-bar-fill" style="width: 42%"></div>
              </div>

              <div class="visual-bar-label">
                <span>Mostly understood</span><span>35%</span>
              </div>
              <div class="visual-bar-track">
                <div
                  class="visual-bar-fill"
                  style="width: 35%; animation-delay: 0.2s"
                ></div>
              </div>

              <div class="visual-bar-label">
                <span>A bit confused</span><span>15%</span>
              </div>
              <div class="visual-bar-track">
                <div
                  class="visual-bar-fill"
                  style="width: 15%; animation-delay: 0.4s"
                ></div>
              </div>

              <div class="visual-bar-label">
                <span>Very lost</span><span>8%</span>
              </div>
              <div class="visual-bar-track">
                <div
                  class="visual-bar-fill"
                  style="width: 8%; animation-delay: 0.6s"
                ></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ── Features ── -->
      <section class="features">
        <div class="features-header">
          <h2>Built for the classroom. Ready for anything.</h2>
          <div class="features-header-line"></div>
        </div>

        <div class="features-grid">
          <div class="feature-cell">
            <div class="feature-icon">📝</div>
            <h3>Classroom Surveys</h3>
            <p>
              Pulse-check understanding, gather feedback, and surface insights —
              all in real time, right from your dashboard.
            </p>
          </div>
          <div class="feature-cell">
            <div class="feature-icon">🚨</div>
            <h3>Disaster Preparedness</h3>
            <p>
              Structured assessments that help schools measure and improve
              readiness across multiple emergency categories.
            </p>
          </div>
          <div class="feature-cell">
            <div class="feature-icon">📊</div>
            <h3>Instant Results</h3>
            <p>
              Teachers see live response summaries the moment students submit.
              No waiting. No manual tallying.
            </p>
          </div>
          <div class="feature-cell">
            <div class="feature-icon">🎓</div>
            <h3>Role-Based Access</h3>
            <p>
              Separate teacher and student views — teachers manage and review,
              students respond with clarity and ease.
            </p>
          </div>
          <div class="feature-cell">
            <div class="feature-icon">🔒</div>
            <h3>Private &amp; Secure</h3>
            <p>
              Responses stay within your classroom. No data sold, no ads, no
              noise — just what you need.
            </p>
          </div>
          <div class="feature-cell">
            <div class="feature-icon">⚡</div>
            <h3>Engage Mode</h3>
            <p>
              Teachers can open a survey live in class and watch participation
              happen in real time on a shared screen.
            </p>
          </div>
        </div>
      </section>

      <!-- ── Quote ── -->
      <div class="quote-strip">
        <blockquote>
          "We hear you — <strong> loud and clear.</strong>"
        </blockquote>
        <cite>The Echo Philosophy</cite>
      </div>

      <!-- ── CTA Banner ── -->
      <div class="cta-banner">
        <h2>Ready to <em>amplify</em> your voice?</h2>
        <div class="cta-actions">
          <a href="/register" class="btn btn-primary btn-lg"
            >Try it for FREE!</a
          >
        </div>
      </div>

      <!-- ── Footer ── -->
      <footer class="hero-footer">
        <span>&copy; <%= new Date().getFullYear() %> Echo &mdash; Group 7</span>
        <div>
          <a href="/team">About us &rarr;</a>
          <a href="/login">Sign in &rarr;</a>
        </div>
      </footer>
    </div>
    <!-- /page -->

    <script>
      const nav = document.getElementById("heroNav");
      window.addEventListener(
        "scroll",
        () => {
          nav.classList.toggle("scrolled", window.scrollY > 10);
        },
        { passive: true },
      );

      function toggleTheme() {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute(
          "data-theme",
          isDark ? "light" : "dark",
        );
        document.getElementById("themeIcon").textContent = isDark ? "🌙" : "☀️";
        localStorage.setItem("theme", isDark ? "light" : "dark");
      }

      // Restore saved preference on load
      const saved =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      if (saved === "dark") {
        document.documentElement.setAttribute("data-theme", "dark");
        document.getElementById("themeIcon").textContent = "☀️";
      }
    </script>
  </body>
</html>
