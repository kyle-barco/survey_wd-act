<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="LIdYcFX6W5zD7tMoaHMibWzvUM-2dQy5RrCvHUH3-78" />

    <% if (locals.user) { %>
      <title>Hello <%=user.name%>, Welcome to Echo!</title>
    <% } else { %>
      <title>Hello User, Welcome to Echo!</title>
    <% } %>
    <link rel="icon" type="image/x-icon" href="../../resources/img/favicon.svg">

    <% if (!isProduction) { %>
        <script type="module" src="http://localhost:5173/@vite/client"></script>
        <script type="module" src="http://localhost:5173/resources/js/main.js"></script>
        <link rel="stylesheet" href="http://localhost:5173/resources/css/style.css">
    <% } else { %>
        <script async src="<%= umamiUrl %>" data-website-id="<%= umamiWebsiteId %>"></script>
        <script type="module" src="/dist/<%= locals.jsFile %>"></script>
        <link rel="stylesheet" href="/dist/<%= locals.cssFile %>">
    <% } %>
</link>
</head>
<body>

<header class="navbar">
    <h1><a class="nav-logo" href="/"><img src="../../resources/img/echo_logo_svg.svg" alt=""></a></h1>

    <!-- Hamburger Toggle -->
    <div class="hamburger" id="hamburger">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <!-- Navigation Links -->
    <nav class="nav-links" id="nav-links">
        <% if (locals.user) { %>
            <button class="btn btn-ghost" id="themeBtn" onclick="toggleTheme()" aria-label="Toggle dark mode">
                <span id="themeIcon">🌙</span> 
            </button>
            <a href="/dashboard">Dashboard</a>
            <a href="/results">Results</a>
            
            <!-- These will only show on mobile -->
            <a href="/profile" class="mobile-only">Profile</a>
            <a href="/logout" class="logout mobile-only">Log out</a>
            <a href="/" class="mobile-only">Back to Home</a>
        <% } else { %>
            <button class="btn btn-ghost" id="themeBtn" onclick="toggleTheme()" aria-label="Toggle dark mode">
                <span id="themeIcon">🌙</span>
            </button>
            <a href="/login">Log in</a>
            <a href="/register">Register</a>
        <% } %>
        <% if (locals.showBack !== false) { %>
            <button class="btn btn-ghost" onclick="history.back()">← Back</button>
        <% } %>
    </nav>
</header>

    <nav>
        <% if (locals.user) { %>
            <span class="nav-section">Surveys</span>
            <a href="/surveys">More Surveys</a>
            <a href="/surveys">Create Survey</a>
            <span class="nav-section">Account</span>
            <a href="/profile">Profile</a>
            <a href="/logout" class="logout">Log out</a>
            <span class="nav-section">More</span>
            <a href="/team">About Us</a>
        <% } else { %>
            <span class="nav-section">Account</span>
            <a href="/login">Log in</a>
            <a href="/register">Register</a>
            <span class="nav-section">More</span>
            <a href="/team">About Group 7</a>
            <a href="/">Facebook</a>
            <a href="/">Instagram</a>
            <a href="/">YouTube</a>
        <% } %>
    </nav>

    <main>
        <%- body %>
    </main>

    <aside>
        <% if (locals.user) { %>
            <span class="aside-section">Signed in as</span>
            <div class="aside-item">
                <span class="aside-label">Name</span>
                <span class="aside-value"><%= user.name %></span>
            </div>
            <div class="aside-item">
                <span class="aside-label">Role</span>
                <span class="aside-value"><%= user.role || 'Student' %></span>
            </div>
        <% } %>
    </aside>

    <footer>
        <script src="/resources/js/navbar.js" defer></script>
        <span>Echo &copy; <%= new Date().getFullYear() %></span>
        <a href="/team">Group 7</a>
    </footer>
    <script>
  function toggleTheme() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
    document.getElementById('themeIcon').textContent = isDark ? '🌙' : '☀️';
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  }

  // Restore saved preference on load
  const saved = localStorage.getItem('theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    document.getElementById('themeIcon').textContent = '☀️';
  }
</script>

</body>
</html>