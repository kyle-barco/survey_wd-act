<div class="profile-container">

  <div class="profile-header">
    <div class="profile-avatar">
      <%= user.name.charAt(0).toUpperCase() %>
    </div>
    <div class="profile-header__info">
      <h1 class="profile-name"><%= user.name %></h1>
      <span class="profile-role-badge profile-role-badge--<%= user.role.toLowerCase() %>">
        <%= user.role %>
      </span>
    </div>
  </div>

  <div class="profile-section">
    <div class="profile-section__title">Account Details</div>

    <div class="profile-field">
      <span class="profile-field__label">Full Name</span>
      <span class="profile-field__value"><%= user.name %></span>
    </div>

    <div class="profile-field">
      <span class="profile-field__label">Email</span>
      <span class="profile-field__value"><%= user.email %></span>
    </div>

    <div class="profile-field">
      <span class="profile-field__label">Role</span>
      <span class="profile-field__value"><%= user.role %></span>
    </div>

    <div class="profile-field">
      <span class="profile-field__label">Member Since</span>
      <span class="profile-field__value"><%= new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
    </div>
  </div>

  <% if (user.role === 'TEACHER') { %>
  <div class="profile-section">
    <div class="profile-section__title">My Surveys</div>

    <% if (surveys && surveys.length > 0) { %>
      <div class="profile-survey-list">
        <% surveys.forEach(survey => { %>
          <div class="profile-survey-item">
            <div class="profile-survey-item__info">
              <span class="profile-survey-item__title"><%= survey.title %></span>
              <span class="profile-survey-item__meta">
                <%= survey.classroom ? survey.classroom.name : 'No classroom' %> &mdash;
                <%= new Date(survey.createdAt).toLocaleDateString() %>
              </span>
            </div>
            <div class="profile-survey-item__actions">
              <a href="/classroom-survey/<%= survey.id %>/results" class="profile-btn profile-btn--sm profile-btn--primary">Results</a>
              <a href="/survey/<%= survey.id %>/edit" class="profile-btn profile-btn--sm profile-btn--ghost">Edit</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="profile-empty">No surveys created yet.</div>
    <% } %>
  </div>

  <div class="profile-section">
    <div class="profile-section__title">My Disaster Surveys</div>

    <% if (disasterSurveys && disasterSurveys.length > 0) { %>
      <div class="profile-survey-list">
        <% disasterSurveys.forEach(survey => { %>
          <div class="profile-survey-item">
            <div class="profile-survey-item__info">
              <span class="profile-survey-item__title"><%= survey.title %></span>
              <span class="profile-survey-item__meta">
                <span class="disaster-badge disaster-badge--<%= survey.category.toLowerCase() %>">
                  <%= survey.category.replace(/_/g, ' ') %>
                </span>
                &mdash; <%= new Date(survey.createdAt).toLocaleDateString() %>
              </span>
            </div>
            <div class="profile-survey-item__actions">
              <a href="/disaster-survey/<%= survey.id %>/results" class="profile-btn profile-btn--sm profile-btn--primary">Results</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="profile-empty">No disaster surveys created yet.</div>
    <% } %>
  </div>
  <% } %>

  <% if (user.role === 'STUDENT') { %>
  <div class="profile-section">
    <div class="profile-section__title">My Responses</div>

    <% if (feedbacks && feedbacks.length > 0) { %>
      <div class="profile-survey-list">
        <% feedbacks.forEach(fb => { %>
          <div class="profile-survey-item">
            <div class="profile-survey-item__info">
              <span class="profile-survey-item__title"><%= fb.survey.title %></span>
              <span class="profile-survey-item__meta">
                Submitted <%= new Date(fb.createdAt).toLocaleDateString() %>
              </span>
            </div>
            <div class="profile-survey-item__actions">
              <a href="/classroom-survey/<%= fb.surveyId %>/results" class="profile-btn profile-btn--sm profile-btn--ghost">View</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="profile-empty">No survey responses yet.</div>
    <% } %>
  </div>
  <% } %>

  <div class="profile-footer">
    <a href="/logout" class="profile-btn profile-btn--danger">Logout</a>
  </div>

</div>