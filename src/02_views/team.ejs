<div class="echo-chart-wrapper">
    <div class="echo-chart-header">
        <h1>Group 7</h1>
        <p class="subtitle">Development Team Chart</p>
    </div>

    <div class="chart-container">
        <% if (typeof team !== 'undefined' && team && team.length > 0) { %>
            
            <div class="tier-1">
                <div class="member-card">
                    <div class="avatar layer-leader">
                        <% if (team[0].imgUrl && team[0].imgUrl !== '') { %>
                            <img src="<%= team[0].imgUrl %>" alt="<%= team[0].name %>">
                        <% } else { %>
                            <%= team[0].name.split(' ').map(n => n[0]).join('') %>
                        <% } %>
                    </div>
                    <p class="name"><%= team[0].name %></p>
                    <p class="role"><%= team[0].role %></p>
                </div>
            </div>

            <div class="tier-2">
                <% for(let i = 1; i < team.length; i++) { %>
                    <div class="member-card">
                        <div class="avatar layer-staff">
                            <% if (team[i].imgUrl && team[i].imgUrl !== '') { %>
                                <img src="<%= team[i].imgUrl %>" alt="<%= team[i].name %>">
                            <% } else { %>
                                <%= team[i].name.split(' ').map(n => n[0]).join('') %>
                            <% } %>
                        </div>
                        <p class="name"><%= team[i].name %></p>
                        <p class="role"><%= team[i].role %></p>
                    </div>
                <% } %>
            </div>

        <% } else { %>
            <p class="no-data">No team members found.</p>
        <% } %>
    </div>
 </div>

<style>
    /* Scoped container to prevent messing up your master layout */
    .echo-chart-wrapper {
        width: 100%;
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
        box-sizing: border-box;
        display: block; 
    }

    .echo-chart-header {
        text-align: center;
        margin-bottom: 48px;
    }

    .echo-chart-header h1 {
        font-size: 2.2rem;
        color: #1e293b;
        margin: 0 0 8px 0;
    }

    .echo-chart-header .subtitle {
        color: #64748b;
        font-size: 1.1rem;
        margin: 0;
    }

    .chart-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }

    /* Card Layout Configs */
    .member-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 24px;
        width: 220px;
        text-align: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        display: inline-block; 
        box-sizing: border-box;
    }

    .avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        margin: 0 auto 16px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
        font-size: 1.2rem;
    }

    .layer-leader {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
    }

    .layer-staff {
        background: linear-gradient(135deg, #06b6d4, #3b82f6);
    }

    .name {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0 0 6px 0;
        color: #1e293b;
        line-height: 1.3;
    }

    .role {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
        font-weight: 500;
        line-height: 1.4;
    }

    /* Desktop Tree Layout Structure */
    .tier-1 {
        margin-bottom: 40px;
        position: relative;
    }

    .tier-1::after {
        content: '';
        position: absolute;
        bottom: -40px;
        left: 50%;
        width: 2px;
        height: 40px;
        background-color: #cbd5e1;
    }

    .tier-2 {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
        width: 100%;
        padding-top: 30px;
        position: relative;
    }

    .tier-2::before {
        content: '';
        position: absolute;
        top: 0;
        left: 12%; 
        right: 12%;
        height: 2px;
        background-color: #cbd5e1;
    }

    .tier-2 .member-card {
        position: relative; 
    }

    .tier-2 .member-card::before {
        content: '';
        position: absolute;
        top: -30px; 
        left: 50%;
        transform: translateX(-50%);
        width: 2px;
        height: 30px;
        background-color: #cbd5e1;
    }

    .no-data {
        color: #64748b;
        text-align: center;
    }

    /* Style for avatar images */
.avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover; /* Prevents stretching, crops to fill the circle evenly */
    display: block;
}

/* Ensure avatar container masks everything correctly */
.avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto 16px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
    font-size: 1.2rem;
    overflow: hidden; /* Crucial for keeping images inside the circle */
}

    /* ========================================================
       Responsive Mobile Breakpoint (768px and smaller)
       ======================================================== */
    @media (max-width: 768px) {
        .tier-2 {
            flex-direction: column;
            align-items: center;
            gap: 32px;
            padding-top: 40px;
        }

        /* 1. Hide the horizontal tree line on mobile */
        .tier-2::before {
            display: none;
        }

/* 2. Fix: Drop the line down from the bottom of the card without overlapping text */
        .tier-1::after {
            content: '';
            position: absolute;
            top: 100%; /* Starts exactly at the bottom edge of Kyle's card */
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 40px; /* Shoots down to meet the horizontal branch line */
            background-color: #cbd5e1;
            z-index: 0; /* Keeps it behind card layers if needed */
        }

        /* 3. Re-orient the staff card connectors */
        .tier-2 .member-card {
            width: 100%;
            max-width: 280px; /* Gives them clean, uniform width on small screens */
        }

        /* 4. Convert top lines into a continuous center timeline connection */
        .tier-2 .member-card::before {
            height: 32px;
            top: -32px;
            z-index: 1;
        }

        /* 5. Hide the trailing line anchor on the very last card element */
        .tier-2 .member-card:last-child::after {
            display: none;
        }
        
        /* 6. Continuous drop line between mobile cards */
        .tier-2 .member-card::after {
            content: '';
            position: absolute;
            bottom: -32px;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 32px;
            background-color: #cbd5e1;
            z-index: 1;
        }
    }
</style>